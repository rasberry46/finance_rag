# Copy to .env and fill in. Load with: export $(cat .env | xargs)
# Or in code: python-dotenv reads .env automatically if installed.

RAG_PROVIDER=bedrock              # "bedrock" for real AWS, "local" for offline
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Optional overrides (defaults are sensible)
# BEDROCK_LLM_ID=us.anthropic.claude-sonnet-4-6
# BEDROCK_EMBED_ID=amazon.titan-embed-text-v2:0
